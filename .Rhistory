# Selecciona solo las columnas numéricas de interés
datos_numeric <- dplyr::select(datos_unidos, mean_area, mean_sla, mean_photo, mean_wue, P50, smr, lmr,
densidad_media, RGR_0_330,tca_0_330,ytlpmpa)
# Imputación con método de componentes principales
res_impute <- imputePCA(datos_numeric, ncp = 3) # ncp = número de componentes
# Realiza PCA con los datos imputados
res_pca <- PCA(res_impute$completeObs, graph = FALSE, scale.unit = TRUE)
pca_nuevo <- fviz_pca_biplot(res_pca,
geom.ind = "point",         # Dibujar puntos para individuos
pointshape = 21,            # Forma del punto
pointsize = 2.5,            # Tamaño del punto
fill.ind = datos_unidos$poblacion,  # Color de relleno por población
col.ind = "black",          # Contorno del punto
#addEllipses = TRUE,         # Agregar elipses por grupo
legend.title = list(fill = "Población"),  # Título de la leyenda
repel = TRUE                # Evita sobreposición de etiquetas
) +
fill_palette("jco") +                    # Paleta de relleno para individuos
color_palette("dose")
ggsave("pca_nuevo_v6.jpg", pca_nuevo, width = 7, height = 5)
