datos_densidad <- read.csv("datos_densidad.csv") %>% dplyr::select(id, densidad_media)
datos_biomasa <- read.csv("datos_biomasa.csv") %>% dplyr::select(-region, -poblacion)
datos_fotosintesis <- read.csv("datos_fotosintesis.csv")
datos_pv_wider <- read.csv("datos_pothidrico2.csv") #%>% pivot_wider(names_from = variable, values_from = valor)%>% mutate(ytlpmpa=ytlpmpa*-1)
datos_rgr <- read.csv("datos_rgr.csv") %>% dplyr::select(RGR_height, RGR_base, RGR_hojas, id)
datos_altura <- read.csv("altura_wide.csv") %>% rename(last_height=last_month) %>% dplyr::select(last_height, id)
datos_base <- read.csv("base_wide.csv") %>% rename(last_base=last_month) %>% dplyr::select(RGR_0_330, id) %>% unique()
datos_hojas <-  read.csv("num_hojas_wide.csv") %>% rename(last_leaves=max_hojas) %>% dplyr::select(tca_0_330, id)
datos_embo <- read.csv("datos_embolismo_poblacion.csv") %>% mutate(P50=P50*-1)
datos_clima <- read.csv("chelsea_clima_1981-2010.csv") %>%  #dataframe con las variables climatologies
filter(country == "MX" & confirmado == "si") %>%
filter(!pob %in% c("CHI", "ATZ")) %>%
dplyr::mutate(pob = dplyr::case_when(
pob == "TAL" ~ "Talpa",
pob == "CAC" ~ "Villa Cacoma",
pob == "YET" ~ "Yetzelalag",
pob == "TEC" ~ "Tecoxco",
pob == "HUT" ~ "Huatusco",
pob == "CUZ" ~ "Cuzalapa",
pob == "ZON" ~ "Zongolica",
TRUE ~ pob  # Esto mantiene los valores originales de `pob` que no coincidan
)) %>%
rename(poblacion = pob) %>%
mutate(
ai_mean = bio12 / (pet_penman_mean * 12),
ai_max = bio12 / (pet_penman_max * 12)
)
datos_clima <-  dplyr::select(datos_clima, poblacion, lat, bio11, bio18, clt_mean, sfcWind_mean)
library(purrr)
lista_datos <- list(
datos_hojas,
datos_base,
datos_densidad,
datos_foliares_prom,
datos_fotosintesis_prom,
datos_pv_wider,
datos_biomasa,
datos_embo
)
# Base: datos_foliares (3 hojas por individuo)
datos_foliares_prom <- datos_foliares %>%
group_by(id, poblacion) %>%
summarise(
mean_area = mean(area, na.rm = TRUE),
mean_sla  = mean(sla, na.rm = TRUE),
.groups = "drop"
)
# Base: fotosíntesis (varias medidas por individuo)
datos_fotosintesis_prom <- datos_fotosintesis %>%
dplyr::select(id, poblacion, Photo, WUE) %>%
group_by(id, poblacion) %>%
summarise(
mean_photo = mean(Photo, na.rm = TRUE),
mean_wue   = mean(WUE, na.rm = TRUE),
.groups = "drop"
)
