ifelse(substr(id, 1, 1) == "L", "Yetzelalag",
ifelse(substr(id, 1, 1) == "M", "Yetzelalag",
ifelse(substr(id, 1, 1) == "N", "Yetzelalag",
ifelse(substr(id, 1, 1) == "O", "Yetzelalag",
ifelse(substr(id, 1, 1) == "P", "Zongolica",
"Otra población"))))))))))))))))) %>%
dplyr::select(-c(poblacion.y, poblacion.x)) %>%
mutate(region = ifelse(poblacion %in% c("Cuzalapa", "Talpa", "Villa Cacoma"), "Pacifico", "Golfo"))
# Selecciona solo las columnas numéricas de interés
datos_numeric <- select(datos_unidos, mean_area, mean_sla, mean_photo, mean_wue, P50, smr, lmr,
