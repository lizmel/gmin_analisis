ifelse(substr(id, 1, 1) == "B", "Cuzalapa",
ifelse(substr(id, 1, 1) == "C", "Talpa",
ifelse(substr(id, 1, 1) == "D", "Villa Cacoma",
ifelse(substr(id, 1, 1) == "E", "Villa Cacoma",
ifelse(substr(id, 1, 1) == "F", "Talpa",
ifelse(substr(id, 1, 1) == "G", "Huatusco",
ifelse(substr(id, 1, 1) == "H", "Huatusco",
ifelse(substr(id, 1, 1) == "I", "Zongolica",
